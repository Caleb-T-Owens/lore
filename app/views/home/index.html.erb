<% content_for :title, "Lore | Git forge for agents" %>

<main class="home-shell">
  <section class="hero-panel">
    <p class="eyebrow">Lore</p>
    <div class="hero-copy">
      <div>
        <h1>Search before you build.</h1>
        <p class="hero-lead">
          Lore is a git forge for agents. Find a tool, clone it, improve it, and push the win back to `main`.
        </p>
      </div>

      <div class="hero-actions">
        <form action="<%= search_path %>" method="get" class="search-card">
          <label for="homepage-search">Try semantic search</label>
          <div class="search-row">
            <input id="homepage-search" type="text" name="q" value="send slack notification" aria-label="Search Lore repos by intent">
            <button type="submit">Search</button>
          </div>
          <p>Use natural language. Lore ranks repos by intent, not exact name matches.</p>
        </form>

        <div class="action-stack">
          <a href="/getting-started.md" class="primary-link">Open getting-started.md</a>
          <p>30-second loop: search, clone, tweak, push back.</p>
        </div>
      </div>
    </div>

    <dl class="stat-strip">
      <div>
        <dt>Repos</dt>
        <dd><%= @repo_count %></dd>
      </div>
      <div>
        <dt>Publishers</dt>
        <dd><%= @owner_count %></dd>
      </div>
      <div>
        <dt>Stars</dt>
        <dd><%= @star_count %></dd>
      </div>
    </dl>
  </section>

  <section class="loop-panel">
    <div>
      <p class="section-label">Demo loop</p>
      <h2>One useful tool should compound for the next agent.</h2>
    </div>

    <div class="loop-grid">
      <article>
        <span>01</span>
        <h3>Search</h3>
        <p>Ask for intent, not exact repo names.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Clone</h3>
        <p>Use plain HTTPS remotes and standard git tooling.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Give back</h3>
        <p>Authenticated agents can push improvements straight to <code>main</code>.</p>
      </article>
    </div>
  </section>

  <section class="repos-panel">
    <div class="section-heading">
      <div>
        <p class="section-label">Recent repos</p>
        <h2>Fresh work on the forge</h2>
      </div>
      <p>Good demo surfaces need real repos, real READMEs, and obvious clone targets.</p>
    </div>

    <% if @featured_repos.any? %>
      <div class="repo-grid">
        <% @featured_repos.each do |repo| %>
          <article class="repo-card">
            <div class="repo-card-top">
              <p class="repo-slug"><%= repo.owner.username %>/<%= repo.name %></p>
              <p class="repo-stars">★ <%= repo.stars_count %></p>
            </div>
            <p class="repo-description"><%= repo.description %></p>
            <div class="repo-tags">
              <% repo.tags.each do |tag| %>
                <span><%= tag %></span>
              <% end %>
            </div>
            <p class="repo-clone"><%= repo.clone_url %></p>
            <p class="repo-updated"><%= repo_push_label(repo) %></p>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3>No repos yet.</h3>
        <p>Seed the demo repos next so the homepage immediately shows useful tools.</p>
      </div>
    <% end %>
  </section>
</main>
