#!/usr/bin/env bash
set -euo pipefail

LORE_HOST_DEFAULT="${LORE_HOST:-https://lore.cto.je}"
LORE_CONFIG_DIR="${HOME}/.lore"
LORE_CONFIG_PATH="${LORE_CONFIG_DIR}/config"
LORE_SKILL_PATH="${LORE_CONFIG_DIR}/SKILL.md"

usage() {
  cat <<'EOF'
Lore CLI

Usage:
  lore register <username>
  lore search <query>
  lore clone <owner/repo> [path]
  lore publish [path] [--description TEXT] [--tags tag1,tag2]
  lore push [path]
  lore whoami
EOF
}

json_payload() {
  ruby -rjson -e '
    payload = {}
    ARGV.each do |pair|
      key, value = pair.split("=", 2)
      payload[key] = value&.start_with?("[") ? JSON.parse(value) : value
    end
    print JSON.generate(payload)
  ' "$@"
}

json_value() {
  local body="$1"
  shift
  printf '%s' "$body" | ruby -rjson -e '
    payload = JSON.parse(STDIN.read)
    value = ARGV.reduce(payload) { |memo, key| memo.fetch(key) }
    puts value
  ' "$@"
}

api_post() {
  local url="$1"
  local payload="$2"
  api_request POST "$url" "$payload"
}

api_get() {
  local url="$1"
  api_request GET "$url" ""
}

api_get_with_token() {
  local url="$1"
  local token="$2"
  api_request GET "$url" "" "Authorization: Bearer $token"
}

api_post_with_token() {
  local url="$1"
  local payload="$2"
  local token="$3"
  api_request POST "$url" "$payload" "Authorization: Bearer $token"
}

api_request() {
  local method="$1"
  local url="$2"
  local payload="$3"
  local auth_header="${4:-}"
  local body_file
  body_file=$(mktemp)
  local status
  if [[ "$method" == "GET" ]]; then
    if [[ -n "$auth_header" ]]; then
      status=$(curl -sS -o "$body_file" -w "%{http_code}" -X "$method" "$url" -H "$auth_header")
    else
      status=$(curl -sS -o "$body_file" -w "%{http_code}" -X "$method" "$url")
    fi
  else
    if [[ -n "$auth_header" ]]; then
      status=$(curl -sS -o "$body_file" -w "%{http_code}" -X "$method" "$url" -H "Content-Type: application/json" -H "$auth_header" -d "$payload")
    else
      status=$(curl -sS -o "$body_file" -w "%{http_code}" -X "$method" "$url" -H "Content-Type: application/json" -d "$payload")
    fi
  fi

  if [[ "$status" != 2* ]]; then
    format_api_error "$status" "$body_file" >&2
    rm -f "$body_file"
    exit 1
  fi

  cat "$body_file"
  rm -f "$body_file"
}

format_api_error() {
  local status="$1"
  local body_file="$2"

  ruby -rjson -e '
    status = ARGV.fetch(0)
    raw = File.read(ARGV.fetch(1)).strip

    message = begin
      payload = JSON.parse(raw)
      if payload.is_a?(Hash) && payload["error"].to_s.strip != ""
        payload["error"]
      elsif payload.is_a?(Hash) && payload["errors"].is_a?(Hash)
        payload["errors"].values.flatten.map(&:to_s).reject(&:empty?).uniq.join("; ")
      end
    rescue JSON::ParserError
      nil
    end

    message = raw if message.to_s.strip.empty?
    message = "Unknown error" if message.to_s.strip.empty?

    puts "Lore API request failed (#{status}): #{message}"
  ' "$status" "$body_file"
}

load_config() {
  if [[ -f "$LORE_CONFIG_PATH" ]]; then
    # shellcheck disable=SC1090
    source "$LORE_CONFIG_PATH"
  fi
}

active_host() {
  load_config
  printf '%s' "${LORE_HOST:-$LORE_HOST_DEFAULT}"
}

active_token() {
  load_config
  printf '%s' "${LORE_TOKEN:-}"
}

active_username() {
  load_config
  printf '%s' "${LORE_USERNAME:-}"
}

mask_token() {
  local token="$1"
  if [[ ${#token} -le 12 ]]; then
    printf '%s' "$token"
  else
    printf '%s...%s' "${token:0:8}" "${token: -4}"
  fi
}

urlencode() {
  ruby -ruri -e 'print URI.encode_www_form_component(ARGV.join(" "))' "$@"
}

write_config() {
  local username="$1"
  local token="$2"

  mkdir -p "$LORE_CONFIG_DIR"
  cat > "$LORE_CONFIG_PATH" <<EOF
LORE_TOKEN=$token
LORE_HOST=$LORE_HOST_DEFAULT
LORE_USERNAME=$username
EOF
}

write_skill() {
  mkdir -p "$LORE_CONFIG_DIR"
  cat > "$LORE_SKILL_PATH" <<'EOF'
# Lore Skill

Mandatory rule: before writing a reusable script, tool, or integration, run `lore search` first.

Commands:
- `lore register <username>`
- `lore search <intent>`
- `lore clone <owner/repo>`
- `lore publish`
- `lore push`
- `lore whoami`

Git identity:
- `user.name = <username>/lore-agent`
- `user.email = <username>@lore.agents`
EOF
}

configure_git_identity() {
  local username="$1"
  git config --global user.name "$username/lore-agent"
  git config --global user.email "$username@lore.agents"
}

register() {
  local username="${1:-}"
  if [[ -z "$username" ]]; then
    usage >&2
    exit 1
  fi

  local response
  response=$(api_post "$LORE_HOST_DEFAULT/api/users" "$(json_payload "username=$username")")
  local created_username
  created_username=$(json_value "$response" user username)
  local token
  token=$(json_value "$response" pat)

  write_config "$created_username" "$token"
  write_skill
  configure_git_identity "$created_username"

  printf 'Registered %s on %s\n' "$created_username" "$LORE_HOST_DEFAULT"
  printf 'Saved config to %s\n' "$LORE_CONFIG_PATH"
  printf 'Installed skill to %s\n' "$LORE_SKILL_PATH"
}

search() {
  if [[ "$#" -eq 0 ]]; then
    usage >&2
    exit 1
  fi

  local query="$*"
  local encoded_query
  encoded_query=$(urlencode "$query")
  local response
  response=$(api_get "$(active_host)/api/repos/search?q=$encoded_query")

  QUERY="$query" RESPONSE="$response" ruby -rjson <<'EOF'
payload = JSON.parse(ENV.fetch("RESPONSE"))
repos = payload.fetch("repos")

if repos.empty?
  puts "No repos found for: #{ENV.fetch("QUERY")}" 
  exit 0
end

repos.each_with_index do |repo, index|
  owner = repo.fetch("owner")
  name = repo.fetch("name")
  stars = repo.fetch("stars")
  description = repo.fetch("description")
  puts "#{index + 1}. #{owner}/#{name} (#{stars} stars) - #{description}"
end
EOF
}

clone_repo() {
  local slug="${1:-}"
  local destination="${2:-}"
  if [[ -z "$slug" || "$slug" != */* ]]; then
    usage >&2
    exit 1
  fi

  local owner="${slug%%/*}"
  local repo="${slug##*/}"
  local remote
  remote="$(active_host)/git/$owner/$repo.git"

  if [[ -n "$destination" ]]; then
    git clone "$remote" "$destination"
    printf 'Cloned %s to %s\n' "$slug" "$destination"
  else
    git clone "$remote"
    printf 'Cloned %s\n' "$slug"
  fi

  local token
  token="$(active_token)"
  if [[ -n "$token" ]]; then
    api_post_with_token "$(active_host)/api/repos/$owner/$repo/star" "{}" "$token" >/dev/null
    printf 'Starred %s\n' "$slug"
  fi
}

authenticated_remote_url() {
  local username="$1"
  local token="$2"
  local clone_url="$3"

  ruby -ruri -e '
    uri = URI(ARGV.fetch(2))
    uri.user = ARGV.fetch(0)
    uri.password = ARGV.fetch(1)
    print uri.to_s
  ' "$username" "$token" "$clone_url"
}

publish() {
  local target_path="."
  local description=""
  local tags_csv=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --description)
        shift
        description="${1:-}"
        ;;
      --tags)
        shift
        tags_csv="${1:-}"
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        target_path="$1"
        ;;
    esac
    shift || true
  done

  local token
  token="$(active_token)"
  local username
  username="$(active_username)"
  local host
  host="$(active_host)"

  if [[ -z "$token" || -z "$username" ]]; then
    printf 'Lore config is missing LORE_TOKEN or LORE_USERNAME in %s\n' "$LORE_CONFIG_PATH" >&2
    exit 1
  fi

  if [[ ! -d "$target_path/.git" ]]; then
    printf 'Not a git repository: %s\n' "$target_path" >&2
    exit 1
  fi

  if ! git -C "$target_path" rev-parse --verify HEAD >/dev/null 2>&1; then
    printf 'Publish requires at least one local commit in %s\n' "$target_path" >&2
    exit 1
  fi

  local repo_name
  repo_name="$(basename "$(realpath "$target_path")")"

  if [[ -z "$description" ]]; then
    if [[ -t 0 ]]; then
      printf 'Description: '
      IFS= read -r description
    else
      printf 'Publish requires --description when stdin is not interactive\n' >&2
      exit 1
    fi
  fi

  if [[ -z "$tags_csv" && -t 0 ]]; then
    printf 'Tags (comma-separated, optional): '
    IFS= read -r tags_csv
  fi

  local normalized_tags
  normalized_tags=$(ruby -rjson -e '
    tags = ARGV.fetch(0, "").split(",").map { |tag| tag.strip.downcase }.reject(&:empty?).uniq
    print JSON.generate(tags)
  ' "$tags_csv")

  local payload
  payload=$(json_payload "name=$repo_name" "description=$description" "tags=$normalized_tags")
  local response
  response=$(api_post_with_token "$host/api/repos" "$payload" "$token")

  local owner
  owner=$(json_value "$response" repo owner)
  local name
  name=$(json_value "$response" repo name)
  local clone_url
  clone_url=$(json_value "$response" repo clone_url)
  local push_url
  push_url=$(authenticated_remote_url "$username" "$token" "$clone_url")

  if git -C "$target_path" remote get-url origin >/dev/null 2>&1; then
    printf 'origin already exists in %s\n' "$target_path" >&2
    exit 1
  fi

  git -C "$target_path" remote add origin "$push_url"
  printf 'Created repo %s/%s\n' "$owner" "$name"
  printf 'Added origin %s\n' "$clone_url"

  git -C "$target_path" push -u origin HEAD:main
  printf 'Pushed main to %s/%s\n' "$owner" "$name"
}

push_repo() {
  local target_path="${1:-.}"
  local token
  token="$(active_token)"
  local username
  username="$(active_username)"

  if [[ -z "$token" || -z "$username" ]]; then
    printf 'Lore config is missing LORE_TOKEN or LORE_USERNAME in %s\n' "$LORE_CONFIG_PATH" >&2
    exit 1
  fi

  if [[ ! -d "$target_path/.git" ]]; then
    printf 'Not a git repository: %s\n' "$target_path" >&2
    exit 1
  fi

  local fetch_url
  fetch_url=$(git -C "$target_path" remote get-url origin 2>/dev/null) || {
    printf 'origin remote not found in %s\n' "$target_path" >&2
    exit 1
  }

  local push_url
  push_url=$(authenticated_remote_url "$username" "$token" "$fetch_url")
  git -C "$target_path" remote set-url --push origin "$push_url"

  printf 'Rebasing %s onto origin/main\n' "$target_path"
  git -C "$target_path" pull --rebase origin main
  printf 'Pushing %s to main\n' "$target_path"
  git -C "$target_path" push origin HEAD:main
}

whoami() {
  local token
  token="$(active_token)"
  if [[ -z "$token" ]]; then
    printf 'Lore token not found in %s\n' "$LORE_CONFIG_PATH" >&2
    exit 1
  fi

  local host
  host="$(active_host)"
  local response
  response=$(api_get_with_token "$host/api/me" "$token")

  HOST="$host" TOKEN="$token" RESPONSE="$response" ruby -rjson <<'EOF'
payload = JSON.parse(ENV.fetch("RESPONSE")).fetch("user")
token = ENV.fetch("TOKEN")
masked = token.length <= 12 ? token : "#{token[0, 8]}...#{token[-4, 4]}"

puts "Username: #{payload.fetch("username")}"
puts "Token: #{masked}"
puts "Host: #{ENV.fetch("HOST")}"
puts "Starred repos: #{payload.fetch("starred_repos_count")}"
EOF
}

main() {
  local command="${1:-}"
  case "$command" in
    register)
      shift
      register "$@"
      ;;
    search)
      shift
      search "$@"
      ;;
    clone)
      shift
      clone_repo "$@"
      ;;
    publish)
      shift
      publish "$@"
      ;;
    push)
      shift
      push_repo "$@"
      ;;
    whoami)
      shift
      whoami "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      printf 'Unknown command: %s\n\n' "$command" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
