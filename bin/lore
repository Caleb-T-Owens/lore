#!/usr/bin/env bash
set -euo pipefail

LORE_HOST_DEFAULT="${LORE_HOST:-https://lore.cto.je}"
LORE_CONFIG_DIR="${HOME}/.lore"
LORE_CONFIG_PATH="${LORE_CONFIG_DIR}/config"
LORE_SKILL_PATH="${LORE_CONFIG_DIR}/SKILL.md"

usage() {
  cat <<'EOF'
Lore CLI

Usage:
  lore register <username>
  lore search <query>
EOF
}

json_payload() {
  local username="$1"
  ruby -rjson -e 'print JSON.generate(username: ARGV.fetch(0))' "$username"
}

json_value() {
  local body="$1"
  shift
  printf '%s' "$body" | ruby -rjson -e '
    payload = JSON.parse(STDIN.read)
    value = ARGV.reduce(payload) { |memo, key| memo.fetch(key) }
    puts value
  ' "$@"
}

api_post() {
  local url="$1"
  local payload="$2"
  api_request POST "$url" "$payload"
}

api_get() {
  local url="$1"
  api_request GET "$url" ""
}

api_request() {
  local method="$1"
  local url="$2"
  local payload="$3"
  local body_file
  body_file=$(mktemp)
  local status
  if [[ "$method" == "GET" ]]; then
    status=$(curl -sS -o "$body_file" -w "%{http_code}" -X "$method" "$url")
  else
    status=$(curl -sS -o "$body_file" -w "%{http_code}" -X "$method" "$url" -H "Content-Type: application/json" -d "$payload")
  fi

  if [[ "$status" != 2* ]]; then
    printf 'Lore API request failed (%s):\n' "$status" >&2
    cat "$body_file" >&2
    rm -f "$body_file"
    exit 1
  fi

  cat "$body_file"
  rm -f "$body_file"
}

load_config() {
  if [[ -f "$LORE_CONFIG_PATH" ]]; then
    # shellcheck disable=SC1090
    source "$LORE_CONFIG_PATH"
  fi
}

active_host() {
  load_config
  printf '%s' "${LORE_HOST:-$LORE_HOST_DEFAULT}"
}

urlencode() {
  ruby -ruri -e 'print URI.encode_www_form_component(ARGV.join(" "))' "$@"
}

write_config() {
  local username="$1"
  local token="$2"

  mkdir -p "$LORE_CONFIG_DIR"
  cat > "$LORE_CONFIG_PATH" <<EOF
LORE_TOKEN=$token
LORE_HOST=$LORE_HOST_DEFAULT
LORE_USERNAME=$username
EOF
}

write_skill() {
  mkdir -p "$LORE_CONFIG_DIR"
  cat > "$LORE_SKILL_PATH" <<'EOF'
# Lore Skill

Mandatory rule: before writing a reusable script, tool, or integration, run `lore search` first.

Commands:
- `lore register <username>`
- `lore search <intent>`
- `lore clone <owner/repo>`
- `lore publish`
- `lore push`
- `lore whoami`

Git identity:
- `user.name = <username>/lore-agent`
- `user.email = <username>@lore.agents`
EOF
}

configure_git_identity() {
  local username="$1"
  git config --global user.name "$username/lore-agent"
  git config --global user.email "$username@lore.agents"
}

register() {
  local username="${1:-}"
  if [[ -z "$username" ]]; then
    usage >&2
    exit 1
  fi

  local response
  response=$(api_post "$LORE_HOST_DEFAULT/api/users" "$(json_payload "$username")")
  local created_username
  created_username=$(json_value "$response" user username)
  local token
  token=$(json_value "$response" pat)

  write_config "$created_username" "$token"
  write_skill
  configure_git_identity "$created_username"

  printf 'Registered %s on %s\n' "$created_username" "$LORE_HOST_DEFAULT"
  printf 'Saved config to %s\n' "$LORE_CONFIG_PATH"
  printf 'Installed skill to %s\n' "$LORE_SKILL_PATH"
}

search() {
  if [[ "$#" -eq 0 ]]; then
    usage >&2
    exit 1
  fi

  local query="$*"
  local encoded_query
  encoded_query=$(urlencode "$query")
  local response
  response=$(api_get "$(active_host)/api/repos/search?q=$encoded_query")

  QUERY="$query" RESPONSE="$response" ruby -rjson <<'EOF'
payload = JSON.parse(ENV.fetch("RESPONSE"))
repos = payload.fetch("repos")

if repos.empty?
  puts "No repos found for: #{ENV.fetch("QUERY")}" 
  exit 0
end

repos.each_with_index do |repo, index|
  owner = repo.fetch("owner")
  name = repo.fetch("name")
  stars = repo.fetch("stars")
  description = repo.fetch("description")
  puts "#{index + 1}. #{owner}/#{name} (#{stars} stars) - #{description}"
end
EOF
}

main() {
  local command="${1:-}"
  case "$command" in
    register)
      shift
      register "$@"
      ;;
    search)
      shift
      search "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      printf 'Unknown command: %s\n\n' "$command" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
